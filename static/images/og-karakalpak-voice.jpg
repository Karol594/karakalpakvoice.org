<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e40af"/>
      <stop offset="100%" stop-color="#3b82f6"/>
    </linearGradient>
  </defs>
  
  <rect width="1200" height="630" fill="url(#bgGradient)"/>
  
  <!-- Logo area -->
  <circle cx="300" cy="315" r="120" fill="#fbbf24" opacity="0.2"/>
  <circle cx="300" cy="315" r="80" fill="#fbbf24"/>
  
  <!-- Traditional pattern in logo -->
  <g fill="#1e40af">
    <polygon points="300,275 320,295 300,315 280,295"/>
    <polygon points="300,315 320,335 300,355 280,335"/>
    <polygon points="280,315 300,335 320,315 300,295"/>
  </g>
  
  <!-- Main text -->
  <text x="500" y="280" fill="white" font-family="serif" font-size="72" font-weight="bold">Қарақалпақ Даўысы</text>
  <text x="500" y="320" fill="#fbbf24" font-family="serif" font-size="36">Karakalpak Voice</text>
  
  <!-- Subtitle -->
  <text x="500" y="380" fill="white" font-family="sans-serif" font-size="28" opacity="0.9">Ғәрезсиз мәлимлеме платформасы</text>
  <text x="500" y="410" fill="#fbbf24" font-family="sans-serif" font-size="24">Independent Information Platform</text>
  
  <!-- Decorative elements -->
  <circle cx="1000" cy="150" r="60" fill="#fbbf24" opacity="0.3"/>
  <circle cx="1050" cy="480" r="40" fill="white" opacity="0.2"/>
  <circle cx="150" cy="100" r="30" fill="#fbbf24" opacity="0.4"/>
  
  <!-- Bottom line -->
  <rect x="0" y="600" width="1200" height="4" fill="#fbbf24"/>
</svg>
