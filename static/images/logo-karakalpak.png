<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Background Circle -->
  <circle cx="100" cy="100" r="90" fill="#1e40af"/>
  
  <!-- Inner elements inspired by traditional patterns -->
  <g fill="#fbbf24">
    <!-- Central diamond pattern -->
    <polygon points="100,60 120,80 100,100 80,80" opacity="0.9"/>
    <polygon points="100,100 120,120 100,140 80,120" opacity="0.9"/>
    <polygon points="80,100 100,120 120,100 100,80" opacity="0.7"/>
    
    <!-- Corner elements -->
    <circle cx="75" cy="75" r="4"/>
    <circle cx="125" cy="75" r="4"/>
    <circle cx="75" cy="125" r="4"/>
    <circle cx="125" cy="125" r="4"/>
  </g>
  
  <!-- Text -->
  <text x="100" y="170" text-anchor="middle" fill="white" font-family="serif" font-size="18" font-weight="bold">Қарақалпақ</text>
  <text x="100" y="185" text-anchor="middle" fill="#fbbf24" font-family="serif" font-size="12">ДАЎЫСЫ</text>
  
  <!-- Border -->
  <circle cx="100" cy="100" r="90" fill="none" stroke="#fbbf24" stroke-width="2"/>
</svg>
